PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/anima
JWT_SECRET=replace_with_a_long_random_string_of_at_least_32_characters
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Optional — production rate limiting (Upstash serverless Redis).
# Leave unset locally; the limiter no-ops when these are absent.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
